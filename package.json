{
  "name": "rl-decal-studio",
  "version": "1.0.3",
  "description": "RL Decal Studio - Rocket League Mod Manager",
  "author": "Oliveira Inc",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64"
  },
  "dependencies": {
    "electron-updater": "^6.1.7"
  },
  "build": {
    "appId": "com.oliveiraski.rldecalstudio",
    "productName": "RL Decal Studio",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "files": [
      "**/*",
      "!mods/**",
      "!dist/**"
    ],
    "extraResources": [
      {
        "from": "mods/",
        "to": "mods/",
        "filter": [
          "**/*.upk"
        ]
      },
      {
        "from": "restaurar_mods/",
        "to": "restaurar_mods/",
        "filter": [
          "**/*.upk"
        ]
      }
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "oliveiraski",
        "repo": "RL-Decal-Studio"
      }
    ]
  },
  "devDependencies": {
    "electron": "^42.5.0",
    "electron-builder": "^24.13.3"
  }
}